# Public application and Solana devnet
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_NAGARIK_PROGRAM_ID=76PwNDW9hANj3tiebTEUdAj4yHYHVMfjcVDPjUWLQmqY
NEXT_PUBLIC_NAGARIK_PUBLIC_PREVIEW=0
NAGARIK_PROGRAM_ID=76PwNDW9hANj3tiebTEUdAj4yHYHVMfjcVDPjUWLQmqY
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
NAGARIK_ALLOWED_ORIGINS=http://localhost:3001

# Durable state and sanitized evidence
# Use "local" for development or "blob" for a writable Vercel deployment.
NAGARIK_STORAGE_MODE=local
BLOB_READ_WRITE_TOKEN=
NAGARIK_READ_MODEL_BLOB_PATH=nagarik-signal/state/read-model.json
NAGARIK_BLOB_WRITE_RETRIES=5
NAGARIK_DATA_DIR=

# Production signing and session security. Generate independent random values.
# NAGARIK_RELAYER_SECRET_KEY accepts a Solana secret array JSON or base64.
NAGARIK_RELAYER_SECRET_KEY=
NAGARIK_SESSION_DERIVATION_SECRET=
NAGARIK_COOKIE_SECRET=
NAGARIK_UPLOAD_RECEIPT_SECRET=
NAGARIK_RATE_LIMIT_SALT=
NAGARIK_RATE_LIMIT_PEPPER=
NAGARIK_STEWARD_SECRET=
NAGARIK_REINDEX_SECRET=

# Bounded abuse-event retention
NAGARIK_REQUEST_EVENT_RETENTION_MS=604800000
NAGARIK_REQUEST_EVENT_LIMIT=5000

# Relayer circuit-breaker settings
NAGARIK_SESSION_MIN_BALANCE_LAMPORTS=3000000
NAGARIK_RELAYER_RESERVE_LAMPORTS=100000000

# Image safety limits
NAGARIK_MAX_IMAGE_PIXELS=20000000
NAGARIK_MAX_OUTPUT_BYTES=2097152

# Optional same-origin base for server-side delivered-evidence checks.
NAGARIK_INTERNAL_APP_URL=

# Optional Supabase adapter target retained by the master architecture.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
