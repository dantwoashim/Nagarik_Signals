{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Viral Sync Fraud Gauntlet",
  "type": "object",
  "required": [
    "type",
    "version",
    "cases",
    "summary"
  ],
  "properties": {
    "type": {
      "const": "viral-sync-fraud-gauntlet"
    },
    "version": {
      "type": "string"
    },
    "proofLevel": {
      "const": "counter_attested"
    },
    "attestationModel": {
      "const": "merchant_terminal_visitor_signed"
    },
    "cases": {
      "type": "array",
      "minItems": 16,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "expected",
          "observed",
          "normalReferralFailure",
          "viralSyncDefense",
          "proofSource",
          "expectedErrorMatched",
          "accountsMutated",
          "accountsMutationVerified",
          "failureKind",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "expected": {
            "const": "rejected"
          },
          "observed": {
            "type": "string",
            "enum": [
              "rejected",
              "missing",
              "not_proven",
              "failed"
            ]
          },
          "normalReferralFailure": {
            "type": "string"
          },
          "viralSyncDefense": {
            "type": "string"
          },
          "proofSource": {
            "type": "string",
            "enum": [
              "devnet_transaction_execution",
              "localnet_transaction_execution",
              "intent_validator_check",
              "mock_final_fixture"
            ]
          },
          "expectedErrorMatched": {
            "type": "boolean"
          },
          "accountsMutated": {
            "type": "boolean"
          },
          "accountsMutationVerified": {
            "type": "boolean"
          },
          "failureKind": {
            "type": "string",
            "enum": [
              "program_rejection",
              "intent_validator_rejection"
            ]
          },
          "evidence": {
            "type": "string"
          },
          "actualError": {
            "type": "string"
          },
          "expectedErrorCode": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "totalCases",
        "blocked",
        "missing",
        "failed"
      ],
      "properties": {
        "totalCases": {
          "type": "number",
          "minimum": 16
        },
        "blocked": {
          "type": "number",
          "minimum": 0
        },
        "missing": {
          "type": "number",
          "minimum": 0
        },
        "failed": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  }
}
