{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Viral Sync Frontier Readiness",
  "type": "object",
  "required": ["type", "status", "gates"],
  "properties": {
    "type": { "const": "viral-sync-frontier-readiness" },
    "status": { "type": "string", "enum": ["BLOCKED", "READY_FOR_FINAL_PROOF_RUN", "GO"] },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "status"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "status": { "type": "string", "enum": ["PASS", "PENDING", "FAIL"] },
          "detail": { "type": "string" }
        }
      }
    }
  }
}
