{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Viral Sync Merchant Validation Kit",
  "type": "object",
  "required": ["type", "version", "validationStatus", "rules", "evidenceSlots"],
  "properties": {
    "type": { "const": "viral-sync-merchant-validation-kit" },
    "version": { "type": "string" },
    "validationStatus": { "type": "string" },
    "merchantAlias": { "type": "string" },
    "rules": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "interviewScript": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "evidenceSlots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "status", "prompt"],
        "properties": {
          "id": { "type": "string" },
          "status": { "type": "string" },
          "requiredForClaimingTraction": { "type": "boolean" },
          "prompt": { "type": "string" }
        }
      }
    }
  }
}
