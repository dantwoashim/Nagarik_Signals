{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "POC-1 Proof-of-Conversion Receipt",
  "type": "object",
  "required": [
    "proofLevel",
    "attestationModel",
    "programId",
    "pdas",
    "hashes",
    "attackEvidence",
    "terminalVerified",
    "visitorVerified",
    "lineageVerified"
  ],
  "properties": {
    "proofLevel": {
      "const": "counter_attested"
    },
    "attestationModel": {
      "const": "merchant_terminal_visitor_signed"
    },
    "programId": {
      "type": "string"
    },
    "terminalVerified": {
      "type": "boolean"
    },
    "visitorVerified": {
      "type": "boolean"
    },
    "lineageVerified": {
      "type": "boolean"
    },
    "pdas": {
      "type": "object",
      "properties": {
        "terminalDevice": {
          "type": "string"
        },
        "terminalAuthority": {
          "type": "string"
        },
        "visitorAuthority": {
          "type": "string"
        },
        "claimPass": {
          "type": "string"
        },
        "causalReceipt": {
          "type": "string"
        },
        "settlementRecord": {
          "type": "string"
        }
      },
      "required": [
        "terminalDevice",
        "terminalAuthority",
        "visitorAuthority",
        "claimPass",
        "causalReceipt",
        "settlementRecord"
      ]
    },
    "attackEvidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "expected",
          "observed"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "expected": {
            "const": "rejected"
          },
          "observed": {
            "type": "string"
          }
        }
      },
      "minItems": 15
    },
    "hashes": {
      "type": "object",
      "required": [
        "intentManifestHash",
        "visitAttestationHash"
      ],
      "properties": {
        "intentManifestHash": {
          "type": "string"
        },
        "visitAttestationHash": {
          "type": "string"
        },
        "lineageProofHash": {
          "type": "string"
        }
      }
    }
  }
}
