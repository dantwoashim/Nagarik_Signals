{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Viral Sync Proof Feed",
  "type": "object",
  "required": ["type", "version", "entries"],
  "properties": {
    "type": { "const": "viral-sync-proof-feed" },
    "version": { "type": "string" },
    "proofLevel": { "const": "counter_attested" },
    "attestationModel": { "const": "merchant_terminal_visitor_signed" },
    "proofStatus": { "type": "string" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "kind", "status", "detail"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "kind": { "type": "string" },
          "status": { "type": "string" },
          "detail": { "type": "string" },
          "verification": {
            "type": "object",
            "properties": {
              "terminalVerified": { "type": "boolean" },
              "visitorVerified": { "type": "boolean" },
              "lineageVerified": { "type": "boolean" },
              "settlementVerified": { "type": "boolean" },
              "nullifierVerified": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
